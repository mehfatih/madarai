---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import BenchmarkPreview from "../../components/sections/BenchmarkPreview.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";
---
<MarketingLayout title="Benchmark Intelligence — Madar AI" description="Compare your app metrics against 2,400+ subscription apps.">
  <div class="page-hero">
    <div class="ph-inner">
      <div class="ph-badge">Benchmark Intelligence</div>
      <h1 class="ph-headline">Stop guessing.<br/><span class="gradient-text">Know where you stand.</span></h1>
      <p class="ph-sub">Compare your CPI, D7 retention, ROAS, LTV, and churn rate against anonymized data from 2,400+ subscription mobile apps in your exact category.</p>
      <a href="/signup" class="ph-cta">See Your Benchmarks Free →</a>
    </div>
  </div>
  <BenchmarkPreview />
  <div class="bm-features">
    <div class="bmf-inner">
      <div class="bmf-grid">
        <div class="bmf-card">
          <div class="bmf-icon">📊</div>
          <h3>10+ Metrics Tracked</h3>
          <p>CPI, ROAS, D1/D7/D30 retention, LTV, churn rate, trial conversion, paywall CVR, and more.</p>
        </div>
        <div class="bmf-card">
          <div class="bmf-icon">🎯</div>
          <h3>Category-Specific</h3>
          <p>Filter by app category — fitness, language, productivity, meditation — for relevant comparisons.</p>
        </div>
        <div class="bmf-card">
          <div class="bmf-icon">🌍</div>
          <h3>Regional Benchmarks</h3>
          <p>MENA, Turkey, EU, and US benchmarks. Know how your app performs in each market.</p>
        </div>
        <div class="bmf-card">
          <div class="bmf-icon">📈</div>
          <h3>Percentile Ranking</h3>
          <p>See exactly where you rank — 78th percentile in CPI means you are better than 78% of similar apps.</p>
        </div>
      </div>
    </div>
  </div>
  <FinalCTA />
</MarketingLayout>
<style>
.page-hero { padding: 120px 24px 80px; background: linear-gradient(180deg,#0F1117,#141929); text-align: center; }
.ph-inner { max-width: 700px; margin: 0 auto; }
.ph-badge { display: inline-block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #F97316; background: rgba(249,115,22,0.1); border: 1px solid rgba(249,115,22,0.25); padding: 4px 16px; border-radius: 999px; margin-bottom: 20px; }
.ph-headline { font-size: clamp(2.5rem,5vw,4rem); font-weight: 800; color: white; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 20px; }
.ph-sub { font-size: 1.1rem; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 32px; }
.ph-cta { display: inline-block; padding: 14px 32px; background: linear-gradient(135deg,#F97316,#EF4444); color: white; text-decoration: none; font-weight: 700; border-radius: 999px; box-shadow: 0 4px 16px rgba(249,115,22,0.35); }
.bm-features { padding: 80px 24px; background: white; }
.bmf-inner { max-width: 900px; margin: 0 auto; }
.bmf-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 24px; }
.bmf-card { padding: 28px; background: #F8F9FA; border: 1px solid #E5E7EB; border-radius: 16px; }
.bmf-icon { font-size: 28px; margin-bottom: 14px; }
.bmf-card h3 { font-size: 16px; font-weight: 700; color: #111827; margin-bottom: 8px; }
.bmf-card p { font-size: 14px; color: #6B7280; line-height: 1.6; }
@media (max-width: 640px) { .bmf-grid { grid-template-columns: 1fr; } }
</style>
