---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="404 — Page Not Found | Madar AI">
  <div class="not-found">
    <div class="nf-inner">
      <div class="nf-logo">
        <a href="/">
          <span class="logo-mark">M</span>
          <span class="logo-text">Madar <span class="logo-ai">AI</span></span>
        </a>
      </div>
      <div class="nf-code">404</div>
      <h1 class="nf-headline">Page not found.</h1>
      <p class="nf-sub">The page you are looking for does not exist or has been moved.</p>
      <div class="nf-actions">
        <a href="/" class="nf-primary">Go to Homepage</a>
        <a href="/resources/docs" class="nf-secondary">Browse Docs</a>
      </div>
      <div class="nf-links">
        <a href="/product">Product</a>
        <a href="/pricing">Pricing</a>
        <a href="/resources/blog">Blog</a>
        <a href="/company/about">About</a>
      </div>
    </div>
  </div>
</BaseLayout>
<style>
.not-found { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #0F1117; padding: 24px; }
.nf-inner { text-align: center; max-width: 480px; }
.nf-logo { margin-bottom: 48px; }
.nf-logo a { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
.logo-mark { width: 40px; height: 40px; background: linear-gradient(135deg,#F97316,#EF4444); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 22px; color: white; }
.logo-text { font-size: 22px; font-weight: 800; color: white; }
.logo-ai { color: #F97316; }
.nf-code { font-size: 8rem; font-weight: 900; font-family: monospace; line-height: 1; background: linear-gradient(135deg,#F97316,#EF4444); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 16px; }
.nf-headline { font-size: 2rem; font-weight: 800; color: white; margin-bottom: 12px; }
.nf-sub { font-size: 1rem; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 32px; }
.nf-actions { display: flex; gap: 12px; justify-content: center; margin-bottom: 32px; flex-wrap: wrap; }
.nf-primary { padding: 12px 28px; background: linear-gradient(135deg,#F97316,#EF4444); color: white; text-decoration: none; font-weight: 700; border-radius: 999px; font-size: 14px; }
.nf-secondary { padding: 12px 28px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); color: white; text-decoration: none; font-weight: 600; border-radius: 999px; font-size: 14px; }
.nf-links { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
.nf-links a { font-size: 14px; color: rgba(255,255,255,0.4); text-decoration: none; }
.nf-links a:hover { color: #F97316; }
</style>
