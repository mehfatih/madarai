---
// Apex login is dead — login lives on app.madarai.co/login. Preserve
// query params so post-login redirect targets (?next=...) survive.
const params = new URLSearchParams(Astro.url.search);
const qs = params.toString();
const target = `https://app.madarai.co/login${qs ? `?${qs}` : ""}`;
return Astro.redirect(target, 302);
---
