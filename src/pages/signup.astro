---
// Apex signup is dead — signup lives on app.madarai.co/signup.
// Preserve incoming query params (utm_*, referrer, etc.) so attribution
// survives the hop. 302 (temporary) so a future redesign can revisit.
const params = new URLSearchParams(Astro.url.search);
const qs = params.toString();
const target = `https://app.madarai.co/signup${qs ? `?${qs}` : ""}`;
return Astro.redirect(target, 302);
---
