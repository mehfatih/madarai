---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Sign Up — Madar AI" description="Create your free Madar AI account.">
  <div class="auth-page">
    <div class="auth-card">
      <a href="/" class="auth-logo">
        <span class="auth-logo-mark">M</span>
        <span class="auth-logo-text">Madar <span class="auth-ai">AI</span></span>
      </a>
      <h1 class="auth-headline">Create your account</h1>
      <p class="auth-sub">Start free. No credit card required.</p>
      <div class="auth-social">
        <button class="auth-social-btn" id="google-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Continue with Google
        </button>
      </div>
      <div class="auth-divider"><span>or</span></div>
      <form class="auth-form" id="signup-form">
        <div class="auth-field">
          <label class="auth-label">Full Name</label>
          <input type="text" name="name" placeholder="Ahmed Al-Rashid" class="auth-input" required />
        </div>
        <div class="auth-field">
          <label class="auth-label">Work Email</label>
          <input type="email" name="email" placeholder="you@company.com" class="auth-input" required />
        </div>
        <div class="auth-field">
          <label class="auth-label">Password</label>
          <input type="password" name="password" placeholder="Min 8 characters" class="auth-input" required minlength="8" />
        </div>
        <div class="auth-field">
          <label class="auth-label">Company / App Name</label>
          <input type="text" name="company" placeholder="FitTrack Pro" class="auth-input" />
        </div>
        <button type="submit" class="auth-submit" id="submit-btn">Create Free Account →</button>
        <p class="auth-terms">By signing up you agree to our <a href="/legal/terms">Terms</a> and <a href="/legal/privacy">Privacy Policy</a>.</p>
      </form>
      <p class="auth-switch">Already have an account? <a href="/login">Log in</a></p>
    </div>
  </div>
</BaseLayout>
<style>
.auth-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #0F1117; padding: 24px; }
.auth-card { width: 100%; max-width: 440px; background: #161B26; border: 1px solid #2A3650; border-radius: 20px; padding: 40px; }
.auth-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; margin-bottom: 28px; justify-content: center; }
.auth-logo-mark { width: 36px; height: 36px; background: linear-gradient(135deg,#F97316,#EF4444); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 20px; color: white; }
.auth-logo-text { font-size: 20px; font-weight: 800; color: white; }
.auth-ai { color: #F97316; }
.auth-headline { font-size: 24px; font-weight: 800; color: white; text-align: center; margin-bottom: 6px; }
.auth-sub { font-size: 14px; color: rgba(255,255,255,0.5); text-align: center; margin-bottom: 24px; }
.auth-social-btn { width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px; padding: 12px; background: white; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; color: #111827; cursor: pointer; transition: all 0.15s; }
.auth-social-btn:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.2); transform: translateY(-1px); }
.auth-divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
.auth-divider::before, .auth-divider::after { content: ""; flex: 1; height: 1px; background: #2A3650; }
.auth-divider span { font-size: 12px; color: rgba(255,255,255,0.3); font-weight: 500; }
.auth-form { display: flex; flex-direction: column; gap: 16px; }
.auth-field { display: flex; flex-direction: column; gap: 6px; }
.auth-label { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.7); }
.auth-input { padding: 12px 14px; background: #1E2535; border: 1px solid #2A3650; border-radius: 10px; color: white; font-size: 14px; outline: none; transition: border-color 0.15s; }
.auth-input:focus { border-color: #F97316; }
.auth-input::placeholder { color: rgba(255,255,255,0.2); }
.auth-submit { padding: 14px; background: linear-gradient(135deg,#F97316,#EF4444); color: white; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; transition: all 0.15s; box-shadow: 0 4px 16px rgba(249,115,22,0.35); margin-top: 4px; }
.auth-submit:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(249,115,22,0.45); }
.auth-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
.auth-terms { font-size: 12px; color: rgba(255,255,255,0.3); text-align: center; line-height: 1.5; }
.auth-terms a { color: rgba(255,255,255,0.5); }
.auth-switch { font-size: 14px; color: rgba(255,255,255,0.4); text-align: center; margin-top: 20px; }
.auth-switch a { color: #F97316; font-weight: 600; text-decoration: none; }
</style>
<script>
  document.getElementById("signup-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    btn.textContent = "Creating account...";
    btn.disabled = true;
    const form = e.target as HTMLFormElement;
    const data = { name: form.name.value, email: form.email.value, password: form.password.value, company: form.company.value };
    try {
      const res = await fetch("/api/auth/signup", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });
      if (res.ok) { window.location.href = "/dashboard"; }
      else { btn.textContent = "Try again"; btn.disabled = false; }
    } catch { btn.textContent = "Try again"; btn.disabled = false; }
  });
  document.getElementById("google-btn")?.addEventListener("click", () => {
    window.location.href = "/api/auth/google";
  });
</script>
