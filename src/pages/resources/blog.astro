---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts.filter((p) => p.data.featured);
const regular = posts.filter((p) => !p.data.featured);

const categoryColors: Record<string, string> = {
  Growth: "#1A56DB",
  AI: "#7C3AED",
  Forecasting: "#22D3EE",
  Benchmarks: "#10B981",
  Product: "#F59E0B",
  "Case Study": "#F97316"
};

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

function slugify(id: string) {
  return id.replace(/\.(md|mdx)$/, "");
}
---

<MarketingLayout title="Blog — Madar AI" description="Insights on mobile growth, AI, and subscription economics.">
  <section class="pt-32 pb-12 px-6 max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <div class="text-[10px] font-mono uppercase tracking-[0.2em] text-[#F97316] mb-3">The Madar Brief</div>
      <h1 class="text-5xl md:text-6xl font-semibold tracking-tight mb-4">
        Intelligence for builders.
      </h1>
      <p class="text-white/60 text-lg max-w-2xl mx-auto">
        Field notes from the frontier of AI-driven mobile growth.
      </p>
    </div>

    {featured.length > 0 && (
      <div class="mb-16">
        <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40 mb-4">Featured</div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
          {featured.slice(0, 2).map((post) => (
            
              href={`/resources/blog/${slugify(post.id)}`}
              class="group relative bg-[#161B26] border border-white/5 rounded-2xl p-8 hover:border-white/15 transition-all overflow-hidden"
            >
              <div
                class="absolute top-0 left-0 right-0 h-px opacity-60"
                style={`background: linear-gradient(90deg, transparent, ${categoryColors[post.data.category]}, transparent)`}
              ></div>
              <div class="flex items-center gap-2 mb-4">
                <span
                  class="text-[10px] font-mono uppercase tracking-[0.18em] px-2 py-1 rounded"
                  style={`background: ${categoryColors[post.data.category]}15; color: ${categoryColors[post.data.category]}`}
                >
                  {post.data.category}
                </span>
                <span class="text-[11px] font-mono text-white/30">{post.data.readingTime} min read</span>
              </div>
              <h2 class="text-2xl font-semibold tracking-tight mb-3 group-hover:text-[#F97316] transition-colors">
                {post.data.title}
              </h2>
              <p class="text-white/60 text-sm leading-relaxed mb-6">{post.data.description}</p>
              <div class="flex items-center justify-between text-[11px] font-mono text-white/40">
                <span>{post.data.author}</span>
                <span>{formatDate(post.data.pubDate)}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {regular.length > 0 && (
      <div>
        <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-white/40 mb-4">All Posts</div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {regular.map((post) => (
            
              href={`/resources/blog/${slugify(post.id)}`}
              class="group bg-[#161B26] border border-white/5 rounded-2xl p-6 hover:border-white/15 transition-all"
            >
              <div class="flex items-center gap-2 mb-4">
                <span
                  class="text-[10px] font-mono uppercase tracking-[0.18em] px-2 py-1 rounded"
                  style={`background: ${categoryColors[post.data.category]}15; color: ${categoryColors[post.data.category]}`}
                >
                  {post.data.category}
                </span>
              </div>
              <h3 class="text-lg font-semibold tracking-tight mb-2 group-hover:text-[#F97316] transition-colors">
                {post.data.title}
              </h3>
              <p class="text-white/60 text-sm leading-relaxed mb-6 line-clamp-3">{post.data.description}</p>
              <div class="flex items-center justify-between text-[11px] font-mono text-white/40 pt-4 border-t border-white/5">
                <span>{formatDate(post.data.pubDate)}</span>
                <span>{post.data.readingTime} min</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</MarketingLayout>