---
const plans = [
  {
    name: "Starter",
    price: "99",
    desc: "Perfect for indie developers and early-stage apps.",
    tier: "starter",
    features: ["1 app connected","Core analytics dashboard","Weekly AI growth report","Email alerts","Community access"],
    cta: "Start Free Trial",
    href: "/signup?plan=starter",
    featured: false,
  },
  {
    name: "Growth",
    price: "499",
    desc: "For serious apps ready to scale intelligently.",
    tier: "growth",
    features: ["Up to 5 apps connected","Real-time AI monitoring","Autonomous action engine","Benchmark intelligence","90-day forecast engine","Slack and WhatsApp alerts","Priority support"],
    cta: "Start Free Trial",
    href: "/signup?plan=growth",
    featured: true,
  },
  {
    name: "Scale",
    price: "1,999",
    desc: "For scale-ups that need enterprise-grade AI growth.",
    tier: "scale",
    features: ["Unlimited apps","Dedicated AI growth agent","Custom benchmark reports","White-glove onboarding","API access","Custom integrations","SLA guarantee"],
    cta: "Book a Demo",
    href: "/signup?plan=scale",
    featured: false,
  },
];
---

<section class="pricing-section">
  <div class="pricing-header">
    <div class="section-label">Pricing</div>
    <h2 class="pricing-headline">Start free. <span class="gradient-text">Scale as you grow.</span></h2>
    <p class="pricing-sub">No credit card required. Cancel anytime. 3x ROI in 60 days — or full refund.</p>
  </div>

  <div class="pricing-stage">
    <div class="pricing-grid">
      {plans.map((plan) => (
        <div class={"plan-card plan-" + plan.tier + (plan.featured ? " plan-featured" : "")}>
          {plan.featured && <div class="featured-badge">⭐ Most Popular</div>}
          <div class="plan-orb"></div>

          <div class="plan-top">
            <div class="plan-name">{plan.name}</div>
            <div class="plan-price-row">
              <span class="price-dollar">$</span>
              <span class="price-num">{plan.price}</span>
              <span class="price-mo">/mo</span>
            </div>
            <p class="plan-desc">{plan.desc}</p>
          </div>

          <div class="plan-divider"></div>

          <ul class="plan-features">
            {plan.features.map((feat) => (
              <li class="plan-feat">
                <span class="feat-check">✓</span>
                <span>{feat}</span>
              </li>
            ))}
          </ul>

          <a href={plan.href} class="plan-cta">{plan.cta}</a>
        </div>
      ))}
    </div>

    <div class="pricing-trust">
      <span>🔒 SOC2 Compliant</span>
      <span class="trust-dot">·</span>
      <span>↩ 60-day money-back</span>
      <span class="trust-dot">·</span>
      <span>✗ Cancel anytime</span>
      <span class="trust-dot">·</span>
      <span>💳 No credit card</span>
    </div>
  </div>

  <p class="pricing-footer">
    Managing a portfolio of apps?
    <a href="/company/contact" class="pricing-contact">Talk to us about custom pricing →</a>
  </p>
</section>

<style>
.pricing-section { padding: var(--space-24) 0; }

.pricing-header {
  max-width: 700px;
  margin: 0 auto var(--space-12);
  
  padding: 0 var(--space-6);
}

.section-label {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-emerald);
  background: rgba(16,185,129,0.1);
  border: 1px solid rgba(16,185,129,0.2);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  margin-bottom: var(--space-4);
}

.pricing-headline {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--text-primary);
  margin-bottom: var(--space-4);
}

.pricing-sub {
  font-size: var(--text-base);
  color: var(--text-muted);
  line-height: 1.7;
}

/* Dark stage */
.pricing-stage { display: flex; flex-direction: column; align-items: center; 
  position: relative;
  padding: var(--space-16) var(--space-6);
  background: linear-gradient(180deg, #080C18 0%, #0D1529 50%, #080C18 100%);
  overflow: hidden;
}

.pricing-stage::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 50% 60% at 15% 50%, rgba(26,86,219,0.10) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 85% 50%, rgba(124,58,237,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 50% 10%, rgba(34,211,238,0.05) 0%, transparent 50%);
  pointer-events: none;
}

.pricing-stage::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
}

/* Grid */
.pricing-grid {
  position: relative;
  z-index: 1;
  max-width: 1060px;
  margin: 0 auto var(--space-10); justify-items: center;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
  align-items: center;
}

/* Card base */
.plan-card {
  position: relative;
  border-radius: var(--radius-2xl);
  padding: var(--space-8);
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.06);
  transition: transform var(--duration-normal) var(--ease-out),
              box-shadow var(--duration-normal) var(--ease-out);
}

.plan-card:hover { transform: translateY(-6px); }

/* Starter */
.plan-starter {
  background: linear-gradient(145deg, #1a1f3a 0%, #232a4a 100%);
}
.plan-starter:hover {
  border-color: rgba(99,102,241,0.4);
  box-shadow: 0 24px 60px rgba(99,102,241,0.15);
}
.plan-starter .plan-name  { color: #818CF8; }
.plan-starter .feat-check { color: #818CF8; }
.plan-starter .plan-cta   {
  background: transparent;
  color: #818CF8;
  border: 1px solid rgba(99,102,241,0.4);
}
.plan-starter .plan-cta:hover {
  background: rgba(99,102,241,0.15);
  border-color: #818CF8;
}
.plan-starter .plan-orb {
  background: #6366F1;
}

/* Growth — featured */
.plan-growth {
  background: linear-gradient(145deg, #0f1d45 0%, #1a3580 100%);
  border-color: rgba(26,86,219,0.5) !important;
  box-shadow: 0 0 0 1px rgba(26,86,219,0.3), 0 32px 80px rgba(26,86,219,0.2);
  transform: translateY(-8px);
}
.plan-growth:hover {
  transform: translateY(-14px) !important;
  box-shadow: 0 0 0 1px rgba(26,86,219,0.5), 0 40px 100px rgba(26,86,219,0.3) !important;
}
.plan-growth .plan-name  { color: #60A5FA; }
.plan-growth .feat-check { color: #34D399; }
.plan-growth .plan-cta   {
  background: linear-gradient(135deg, #1A56DB, #2563EB);
  color: white;
  box-shadow: 0 8px 24px rgba(26,86,219,0.4);
}
.plan-growth .plan-cta:hover {
  box-shadow: 0 12px 32px rgba(26,86,219,0.6);
  filter: brightness(1.1);
}
.plan-growth .plan-orb { background: #1A56DB; }

/* Scale */
.plan-scale {
  background: linear-gradient(145deg, #1a0f3a 0%, #2d1a60 100%);
}
.plan-scale:hover {
  border-color: rgba(124,58,237,0.4);
  box-shadow: 0 24px 60px rgba(124,58,237,0.15);
}
.plan-scale .plan-name  { color: #A78BFA; }
.plan-scale .feat-check { color: #A78BFA; }
.plan-scale .plan-cta   {
  background: transparent;
  color: #A78BFA;
  border: 1px solid rgba(124,58,237,0.4);
}
.plan-scale .plan-cta:hover {
  background: rgba(124,58,237,0.15);
  border-color: #A78BFA;
}
.plan-scale .plan-orb { background: #7C3AED; }

/* Orb glow inside card */
.plan-orb {
  position: absolute;
  width: 180px;
  height: 180px;
  border-radius: 50%;
  filter: blur(70px);
  opacity: 0.12;
  top: -50px;
  right: -50px;
  pointer-events: none;
}

/* Featured badge */
.featured-badge {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #1A56DB, #22D3EE);
  color: white;
  font-size: 11px;
  font-weight: 700;
  padding: 5px var(--space-4);
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  white-space: nowrap;
  letter-spacing: 0.05em;
}

/* Plan content */
.plan-top { margin-bottom: var(--space-5); position: relative; padding-top: var(--space-4); }

.plan-name {
  font-size: var(--text-xs);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: var(--space-4);
}

.plan-price-row {
  display: flex;
  align-items: baseline;
  gap: 2px;
  margin-bottom: var(--space-2);
}

.price-dollar { font-size: var(--text-xl); font-weight: 600; color: rgba(255,255,255,0.4); }
.price-num    { font-size: 3.2rem; font-weight: 900; color: white; font-family: var(--font-mono); line-height: 1; letter-spacing: -0.02em; }
.price-mo     { font-size: var(--text-base); color: rgba(255,255,255,0.35); }

.plan-desc {
  font-size: var(--text-sm);
  color: rgba(255,255,255,0.45);
  line-height: 1.5;
}

.plan-divider {
  height: 1px;
  background: rgba(255,255,255,0.06);
  margin-bottom: var(--space-5);
}

.plan-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-bottom: var(--space-7);
}

.plan-feat {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-size: var(--text-sm);
  color: rgba(255,255,255,0.7);
}

.feat-check {
  font-weight: 900;
  font-size: var(--text-sm);
  flex-shrink: 0;
  width: 16px;
}

.plan-cta {
  display: block;
  
  padding: 14px var(--space-4);
  border-radius: var(--radius-lg);
  font-size: var(--text-sm);
  font-weight: 700;
  text-decoration: none;
  transition: all var(--duration-fast);
  letter-spacing: 0.02em;
}

/* Trust */
.pricing-trust {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  flex-wrap: wrap;
  font-size: var(--text-sm);
  color: rgba(255,255,255,0.3);
}

.trust-dot { color: rgba(255,255,255,0.12); }

/* Footer */
.pricing-footer { text-align: center; font-size: var(--text-sm); color: var(--text-muted); padding: var(--space-8) var(--space-6) 0; width: 100%; }

.pricing-contact {
  color: var(--color-cobalt);
  text-decoration: none;
  font-weight: 600;
  margin-left: var(--space-1);
}
.pricing-contact:hover { text-decoration: underline; }

@media (max-width: 1024px) {
  .pricing-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto var(--space-10); justify-items: center; }
  .plan-growth  { transform: translateY(0); }
}
</style>




