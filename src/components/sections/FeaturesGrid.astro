---
const features = [
  { color: "cobalt",  icon: "AI",  title: "AI Growth Brain",       desc: "A multi-agent system with 12 specialized AI agents. Your Virtual Head of Growth, available 24/7.", tags: ["Multi-Agent","Always On","Autonomous"] },
  { color: "emerald", icon: "REV", title: "Revenue Shield",         desc: "Real-time monitoring of MRR, LTV, ROAS, and subscription health. Detects revenue threats instantly.", tags: ["MRR Tracking","ROAS Monitor","LTV Curves"] },
  { color: "cyan",    icon: "FOR", title: "Forecast Engine",        desc: "Predicts your app financial status 12 to 90 days ahead. Know when ROAS will drop before it does.", tags: ["90-Day Forecast","Confidence Bands","Scenarios"] },
  { color: "purple",  icon: "ACT", title: "Autonomous Actions",     desc: "AI suggests. You approve. AI executes. Budget changes, adset pauses, A/B tests — one click.", tags: ["One-Click Execute","Audit Trail","Reversible"] },
  { color: "amber",   icon: "BEN", title: "Benchmark Intelligence", desc: "Compare your CPI, D7 retention, ROAS against 2400+ apps in your category. Know where you stand.", tags: ["Industry Benchmarks","Percentile","Category Filters"] },
  { color: "crimson", icon: "ALT", title: "Early Warning System",   desc: "Detects creative fatigue, audience saturation, and churn spikes 72 hours before standard dashboards.", tags: ["72h Early Warning","Slack Alerts","Root Cause AI"] },
];
---
<section class="features-section">
  <div class="features-inner">
    <div class="section-label">Core Capabilities</div>
    <h2 class="features-headline">Six AI systems. One command center.</h2>
    <p class="features-sub">Every feature is connected. Every insight is actionable. Every action is explainable.</p>
    <div class="features-grid">
      {features.map((f) => (
        <div class={"feature-card feature-" + f.color}>
          <div class={"feature-icon-wrap icon-" + f.color}>
            <span class="feature-icon-text">{f.icon}</span>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
          <div class="feature-tags">
            {f.tags.map((tag) => (
              <span class={"feature-tag tag-" + f.color}>{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
.features-section { padding: var(--space-24) var(--space-6); background: linear-gradient(180deg, transparent, rgba(26,86,219,0.03), transparent); }
.features-inner { max-width: 1200px; margin: 0 auto; text-align: center; }
.section-label { display: inline-block; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-cobalt); background: rgba(26,86,219,0.1); border: 1px solid rgba(26,86,219,0.2); padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); margin-bottom: var(--space-4); }
.features-headline { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: var(--space-4); color: var(--text-primary); }
.features-sub { font-size: var(--text-lg); color: var(--text-muted); margin-bottom: var(--space-12); line-height: 1.6; }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); text-align: left; }
.feature-card { padding: var(--space-8); background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-xl); transition: all var(--duration-normal) var(--ease-out); }
.feature-card:hover { transform: translateY(-6px); }
.feature-cobalt:hover  { border-color: rgba(26,86,219,0.4);  box-shadow: 0 20px 60px rgba(26,86,219,0.12);  }
.feature-emerald:hover { border-color: rgba(16,185,129,0.4); box-shadow: 0 20px 60px rgba(16,185,129,0.12); }
.feature-cyan:hover    { border-color: rgba(34,211,238,0.4); box-shadow: 0 20px 60px rgba(34,211,238,0.12); }
.feature-purple:hover  { border-color: rgba(124,58,237,0.4); box-shadow: 0 20px 60px rgba(124,58,237,0.12); }
.feature-amber:hover   { border-color: rgba(245,158,11,0.4); box-shadow: 0 20px 60px rgba(245,158,11,0.12); }
.feature-crimson:hover { border-color: rgba(220,38,38,0.4);  box-shadow: 0 20px 60px rgba(220,38,38,0.12);  }
.feature-icon-wrap { width: 52px; height: 52px; border-radius: var(--radius-lg); display: flex; align-items: center; justify-content: center; margin-bottom: var(--space-4); }
.icon-cobalt  { background: rgba(26,86,219,0.15);  }
.icon-emerald { background: rgba(16,185,129,0.15); }
.icon-cyan    { background: rgba(34,211,238,0.15); }
.icon-purple  { background: rgba(124,58,237,0.15); }
.icon-amber   { background: rgba(245,158,11,0.15); }
.icon-crimson { background: rgba(220,38,38,0.15);  }
.feature-icon-text { font-size: var(--text-xs); font-weight: 800; font-family: var(--font-mono); color: var(--text-muted); }
.feature-title { font-size: var(--text-xl); font-weight: 700; color: var(--text-primary); margin-bottom: var(--space-3); }
.feature-desc { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.7; margin-bottom: var(--space-4); }
.feature-tags { display: flex; flex-wrap: wrap; gap: var(--space-2); }
.feature-tag { font-size: 11px; font-weight: 600; padding: 3px var(--space-2); border-radius: var(--radius-sm); font-family: var(--font-mono); }
.tag-cobalt  { background: rgba(26,86,219,0.1);  color: var(--color-cobalt);  }
.tag-emerald { background: rgba(16,185,129,0.1); color: var(--color-emerald); }
.tag-cyan    { background: rgba(34,211,238,0.1); color: var(--color-cyan);    }
.tag-purple  { background: rgba(124,58,237,0.1); color: var(--color-purple);  }
.tag-amber   { background: rgba(245,158,11,0.1); color: var(--color-amber);   }
.tag-crimson { background: rgba(220,38,38,0.1);  color: var(--color-crimson); }
@media (max-width: 1024px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px)  { .features-grid { grid-template-columns: 1fr; } }
</style>