---

<section class="hero" id="hero">

  <!-- Animated Background -->
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-grid"></div>
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
  </div>

  <div class="hero-inner">

    <!-- Badge -->
    <div class="hero-badge">
      <span class="badge-dot"></span>
      <span>AI Growth Operating System — Now Live</span>
    </div>

    <!-- Headline -->
    <h1 class="hero-headline">
      Your App's Growth<br/>
      <span class="gradient-text">Now on Autopilot</span>
    </h1>

    <!-- Subheadline -->
    <p class="hero-sub">
      Madar AI is the intelligence layer your mobile app has been missing.
      Not a dashboard. Not a chatbot. A complete AI Growth Brain that
      <strong>predicts problems</strong>, <strong>finds opportunities</strong>,
      and <strong>takes action</strong> — before you even open your laptop.
    </p>

    <!-- CTAs -->
    <div class="hero-ctas">
      <a href="/signup" class="cta-primary">
        Start Free — No Credit Card
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#demo" class="cta-secondary">
        <span class="play-icon">▶</span>
        See it in action
      </a>
    </div>

    <!-- Social Proof Numbers -->
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">2,400+</span>
        <span class="stat-label">Apps on waitlist</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">.2M</span>
        <span class="stat-label">Ad spend managed</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">38%</span>
        <span class="stat-label">Avg churn reduction</span>
      </div>
    </div>

  </div>

  <!-- Dashboard Mockup -->
  <div class="hero-mockup" id="hero-mockup">
    <div class="mockup-window">
      <div class="mockup-bar">
        <div class="mockup-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-amber"></span>
          <span class="dot dot-green"></span>
        </div>
        <div class="mockup-title">Madar AI — Growth Command Center</div>
      </div>

      <div class="mockup-body">
        <!-- Metric Cards Row -->
        <div class="mockup-metrics">
          <div class="metric-card metric-cobalt">
            <div class="metric-label">MRR</div>
            <div class="metric-value">,240</div>
            <div class="metric-delta positive">↑ 12.4%</div>
          </div>
          <div class="metric-card metric-emerald">
            <div class="metric-label">ROAS</div>
            <div class="metric-value">4.2x</div>
            <div class="metric-delta positive">↑ 0.8x</div>
          </div>
          <div class="metric-card metric-crimson">
            <div class="metric-label">Churn</div>
            <div class="metric-value">3.1%</div>
            <div class="metric-delta negative">↓ 1.2%</div>
          </div>
          <div class="metric-card metric-cyan">
            <div class="metric-label">LTV</div>
            <div class="metric-value"></div>
            <div class="metric-delta positive">↑ 18%</div>
          </div>
        </div>

        <!-- AI Insight -->
        <div class="mockup-ai-insight">
          <div class="ai-badge">
            <span class="ai-dot"></span>
            AI Insight
          </div>
          <p class="ai-text">
            🔮 Turkey CPI increased 31% in last 48h. Creative fatigue detected on Ad Set #4.
            <strong>Recommend pausing and rotating to variant B.</strong>
            Expected ROAS recovery: +0.6x within 72 hours.
          </p>
          <div class="ai-actions">
            <button class="ai-btn-approve">✓ Approve Action</button>
            <button class="ai-btn-dismiss">Dismiss</button>
          </div>
        </div>

        <!-- Mini Chart -->
        <div class="mockup-chart">
          <div class="chart-label">MRR Forecast — Next 90 Days</div>
          <svg class="chart-svg" viewBox="0 0 400 80" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Grid lines -->
            <line x1="0" y1="20" x2="400" y2="20" stroke="#1E2A3A" stroke-width="1"/>
            <line x1="0" y1="40" x2="400" y2="40" stroke="#1E2A3A" stroke-width="1"/>
            <line x1="0" y1="60" x2="400" y2="60" stroke="#1E2A3A" stroke-width="1"/>
            <!-- Confidence band -->
            <path d="M0 55 C50 50 100 45 150 42 C200 39 250 35 300 30 C350 25 400 20 400 18 L400 28 C350 32 300 38 250 43 C200 48 150 52 100 55 C50 58 0 62 0 62 Z" fill="rgba(34,211,238,0.08)"/>
            <!-- Main line -->
            <path d="M0 58 C50 53 100 48 150 44 C200 40 250 36 300 31 C350 26 400 21 400 20" stroke="#22D3EE" stroke-width="2" stroke-linecap="round"/>
            <!-- Glow -->
            <path d="M0 58 C50 53 100 48 150 44 C200 40 250 36 300 31 C350 26 400 21 400 20" stroke="#22D3EE" stroke-width="6" stroke-linecap="round" opacity="0.2"/>
            <!-- Today marker -->
            <line x1="200" y1="10" x2="200" y2="70" stroke="#1A56DB" stroke-width="1" stroke-dasharray="3,3"/>
            <circle cx="200" cy="40" r="4" fill="#1A56DB"/>
          </svg>
          <div class="chart-footer">
            <span class="chart-tag cyan">Forecast: +,400 in 90 days</span>
            <span class="chart-tag cobalt">Confidence: 84%</span>
          </div>
        </div>

      </div>
    </div>
  </div>

</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120px var(--space-6) var(--space-24);
  overflow: hidden;
}

/* Background */
.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.hero-gradient {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 50% at 50% -10%, rgba(26,86,219,0.15) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 50%, rgba(124,58,237,0.08) 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 20% 60%, rgba(34,211,238,0.06) 0%, transparent 50%);
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--border-subtle) 1px, transparent 1px),
    linear-gradient(90deg, var(--border-subtle) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  opacity: 0.3;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  animation: orbFloat 8s ease-in-out infinite;
}

.hero-orb-1 {
  width: 400px; height: 400px;
  background: rgba(249,115,22,0.08);
  top: -100px; left: -100px;
  animation-delay: 0s;
}

.hero-orb-2 {
  width: 300px; height: 300px;
  background: rgba(249,115,22,0.06);
  top: 20%; right: -80px;
  animation-delay: 3s;
}

.hero-orb-3 {
  width: 250px; height: 250px;
  background: rgba(26,86,219,0.05);
  bottom: 10%; left: 30%;
  animation-delay: 5s;
}

@keyframes orbFloat {
  0%, 100% { transform: translateY(0px) scale(1); }
  50%       { transform: translateY(-30px) scale(1.05); }
}

/* Content */
.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 760px;
  text-align: center;
  margin-bottom: var(--space-16);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  background: rgba(26,86,219,0.1);
  border: 1px solid rgba(26,86,219,0.3);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  color: var(--color-cobalt);
  font-weight: 500;
  margin-bottom: var(--space-6);
  animation: fadeUp 0.6s var(--ease-out) both;
}

.badge-dot {
  width: 8px; height: 8px;
  background: var(--color-cobalt);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
  box-shadow: 0 0 8px var(--color-cobalt);
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.6; transform: scale(0.8); }
}

.hero-headline {
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 800;
  line-height: 1.1;
  color: var(--text-primary);
  margin-bottom: var(--space-6);
  letter-spacing: -0.02em;
  animation: fadeUp 0.6s var(--ease-out) 0.1s both;
}

.hero-sub {
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: var(--space-8);
  animation: fadeUp 0.6s var(--ease-out) 0.2s both;
}

.hero-sub strong {
  color: var(--text-primary);
  font-weight: 600;
}

.hero-ctas {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  margin-bottom: var(--space-8);
  animation: fadeUp 0.6s var(--ease-out) 0.3s both;
  flex-wrap: wrap;
}

.cta-primary {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-6);
  background: var(--color-cobalt);
  color: white;
  text-decoration: none;
  font-size: var(--text-base);
  font-weight: 700;
  border-radius: var(--radius-lg);
  box-shadow: var(--glow-cobalt);
  transition: all var(--duration-normal) var(--ease-out);
}

.cta-primary:hover {
  background: #1e63f5;
  transform: translateY(-2px);
  box-shadow: 0 0 40px rgba(26,86,219,0.6);
}

.cta-secondary {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-6);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  border: 1px solid var(--glass-border);
  color: var(--text-primary);
  text-decoration: none;
  font-size: var(--text-base);
  font-weight: 600;
  border-radius: var(--radius-lg);
  transition: all var(--duration-normal) var(--ease-out);
}

.cta-secondary:hover {
  border-color: var(--color-cobalt);
  color: var(--color-cobalt);
}

.play-icon {
  font-size: 12px;
  color: var(--color-cobalt);
}

/* Stats */
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-6);
  animation: fadeUp 0.6s var(--ease-out) 0.4s both;
}

.stat { text-align: center; }

.stat-value {
  display: block;
  font-size: var(--text-2xl);
  font-weight: 800;
  color: var(--text-primary);
  font-family: var(--font-mono);
}

.stat-label {
  font-size: var(--text-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.stat-divider {
  width: 1px;
  height: 40px;
  background: var(--border-subtle);
}

/* Mockup */
.hero-mockup {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 900px;
  animation: fadeUp 0.8s var(--ease-out) 0.5s both;
}

.mockup-window {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow:
    0 40px 120px rgba(0,0,0,0.6),
    0 0 0 1px var(--border-subtle),
    inset 0 1px 0 rgba(255,255,255,0.05);
}

.mockup-bar {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  background: var(--bg-section);
  border-bottom: 1px solid var(--border-subtle);
}

.mockup-dots { display: flex; gap: 6px; }

.dot {
  width: 12px; height: 12px;
  border-radius: 50%;
}

.dot-red    { background: #FF5F57; }
.dot-amber  { background: #FFBD2E; }
.dot-green  { background: #28C840; }

.mockup-title {
  font-size: var(--text-xs);
  color: var(--text-muted);
  font-family: var(--font-mono);
}

.mockup-body {
  padding: var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

/* Metric Cards */
.mockup-metrics {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-3);
}

.metric-card {
  padding: var(--space-4);
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-subtle);
  transition: all var(--duration-normal);
}

.metric-cobalt  { border-color: rgba(26,86,219,0.3);  }
.metric-emerald { border-color: rgba(16,185,129,0.3); }
.metric-crimson { border-color: rgba(220,38,38,0.3);  }
.metric-cyan    { border-color: rgba(34,211,238,0.3); }

.metric-label {
  font-size: var(--text-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: var(--space-1);
}

.metric-value {
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--text-primary);
  font-family: var(--font-mono);
  margin-bottom: var(--space-1);
}

.metric-delta {
  font-size: var(--text-sm);
  font-weight: 600;
  font-family: var(--font-mono);
}

.metric-delta.positive { color: var(--color-emerald); }
.metric-delta.negative { color: var(--color-crimson); }

/* AI Insight */
.mockup-ai-insight {
  padding: var(--space-4);
  background: rgba(124,58,237,0.08);
  border: 1px solid rgba(124,58,237,0.25);
  border-radius: var(--radius-lg);
}

.ai-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-purple);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: var(--space-2);
}

.ai-dot {
  width: 6px; height: 6px;
  background: var(--color-purple);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

.ai-text {
  font-size: var(--text-sm);
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: var(--space-3);
}

.ai-actions {
  display: flex;
  gap: var(--space-2);
}

.ai-btn-approve {
  padding: var(--space-1) var(--space-3);
  background: var(--color-emerald);
  color: white;
  border: none;
  border-radius: var(--radius-md);
  font-size: var(--text-xs);
  font-weight: 600;
  cursor: pointer;
  transition: all var(--duration-fast);
}

.ai-btn-approve:hover { opacity: 0.9; }

.ai-btn-dismiss {
  padding: var(--space-1) var(--space-3);
  background: transparent;
  color: var(--text-muted);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  font-size: var(--text-xs);
  cursor: pointer;
  transition: all var(--duration-fast);
}

.ai-btn-dismiss:hover { color: var(--text-primary); }

/* Chart */
.mockup-chart {
  padding: var(--space-4);
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
}

.chart-label {
  font-size: var(--text-xs);
  color: var(--text-muted);
  margin-bottom: var(--space-3);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.chart-svg { width: 100%; height: auto; }

.chart-footer {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-2);
}

.chart-tag {
  font-size: var(--text-xs);
  font-weight: 600;
  padding: 2px var(--space-2);
  border-radius: var(--radius-sm);
  font-family: var(--font-mono);
}

.chart-tag.cyan   { background: rgba(34,211,238,0.1);  color: var(--color-cyan);  }
.chart-tag.cobalt { background: rgba(26,86,219,0.1);   color: var(--color-cobalt); }

/* Animations */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Responsive */
@media (max-width: 768px) {
  .mockup-metrics { grid-template-columns: repeat(2, 1fr); }
  .hero-stats { gap: var(--space-4); }
  .cta-primary, .cta-secondary { width: 100%; justify-content: center; }
}

@media (max-width: 480px) {
  .mockup-metrics { grid-template-columns: repeat(2, 1fr); }
  .mockup-chart { display: none; }
}
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Parallax on mockup
  gsap.to('#hero-mockup', {
    yPercent: 15,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true,
    },
  });

  // Animate metric values counting up
  document.querySelectorAll('.metric-value').forEach(el => {
    const text = el.textContent || '';
    const num = parseFloat(text.replace(/[^0-9.]/g, ''));
    if (isNaN(num)) return;
    const prefix = text.match(/^[^0-9]*/)?.[0] || '';
    const suffix = text.match(/[^0-9.]+$/)?.[0] || '';
    gsap.from(el, {
      textContent: 0,
      duration: 1.5,
      delay: 0.8,
      ease: 'power2.out',
      snap: { textContent: suffix.includes('%') ? 0.1 : 1 },
      onUpdate() {
        const val = parseFloat((el as HTMLElement).textContent || '0');
        (el as HTMLElement).textContent = prefix + val.toFixed(suffix.includes('%') ? 1 : 0) + suffix;
      },
    });
  });
</script>



