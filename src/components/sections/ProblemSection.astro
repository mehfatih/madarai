---
const problems = [
  { icon: "problem-1", title: "5 tools. 5 tabs. Still no answers.", desc: "You switch between Mixpanel, Adjust, Meta Ads, RevenueCat, and your spreadsheet every morning and still leave without knowing what to do next." },
  { icon: "problem-2", title: "You find out about problems too late.", desc: "By the time you notice churn spiked or ROAS dropped, you have already lost thousands. Dashboards show the past. You need the future." },
  { icon: "problem-3", title: "You spend hours on analysis, not growth.", desc: "Your real job is building a great product. Instead you are buried in reports, trying to connect dots that should connect themselves." },
];
---
<section class="problem-section"><div class="problem-inner">
<div class="section-label">The Problem</div>
<h2 class="problem-headline">You have data. You still do not know what to do.</h2>
<p class="problem-sub">Every mobile app founder we talked to had the same story. Too many tools. Too little signal. No time to act.</p>
<div class="problems-grid">
{problems.map((p, i) => (<div class="problem-card"><div class="problem-title">{p.title}</div><p class="problem-desc">{p.desc}</p></div>))}
</div>
<div class="solution-bridge"><div class="bridge-line"></div><div class="bridge-text"><span class="bridge-label">Madar AI fixes all three</span></div><div class="bridge-line"></div></div>
</div></section>
<style>
.problem-section { padding: var(--space-24) var(--space-6); }
.problem-inner { max-width: 1080px; margin: 0 auto; text-align: center; }
.section-label { display: inline-block; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-crimson); background: rgba(220,38,38,0.1); border: 1px solid rgba(220,38,38,0.2); padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); margin-bottom: var(--space-4); }
.problem-headline { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: var(--space-4); color: var(--text-primary); }
.problem-sub { font-size: var(--text-lg); color: var(--text-muted); max-width: 560px; margin: 0 auto var(--space-12); line-height: 1.6; }
.problems-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); margin-bottom: var(--space-12); }
.problem-card { padding: var(--space-8); background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-xl); text-align: left; transition: all var(--duration-normal) var(--ease-out); }
.problem-card:hover { border-color: rgba(220,38,38,0.3); transform: translateY(-4px); }
.problem-title { font-size: var(--text-lg); font-weight: 700; color: var(--text-primary); margin-bottom: var(--space-3); }
.problem-desc { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.7; }
.solution-bridge { display: flex; align-items: center; gap: var(--space-4); }
.bridge-line { flex: 1; height: 1px; background: var(--border-subtle); }
.bridge-label { font-size: var(--text-sm); font-weight: 600; color: var(--color-cobalt); white-space: nowrap; }
@media (max-width: 768px) { .problems-grid { grid-template-columns: 1fr; } }
</style>
