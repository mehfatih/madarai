---
// Footer.astro — Deep navy footer with mint accents
---

<footer class="madar-footer">
  <div class="footer-glow-top"></div>

  <div class="footer-inner">
    <div class="footer-grid">

      <div class="footer-brand-col">
        <a href="/" class="footer-brand">
          <div class="footer-logo">
            <span>M</span>
          </div>
          <div class="footer-brand-text">
            <span class="footer-brand-name">Madar <span class="footer-brand-ai">AI</span></span>
            <span class="footer-brand-sub">GROWTH OS</span>
          </div>
        </a>
        <p class="footer-tagline">
          The AI Growth Operating System for subscription mobile apps. Not a dashboard. A brain.
        </p>

        <div class="footer-status">
          <span class="status-dot"></span>
          <span class="status-text">All systems operational</span>
        </div>

        <div class="footer-socials">
          <a href="https://twitter.com/madarai" aria-label="Twitter" class="social-link">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://linkedin.com/company/madarai" aria-label="LinkedIn" class="social-link">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/madarai" aria-label="GitHub" class="social-link">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <div class="col-title">PRODUCT</div>
        <a href="/product/copilot">Growth Copilot</a>
        <a href="/product/benchmarks">Benchmark Engine</a>
        <a href="/product/forecasting">Forecasting</a>
        <a href="/product/autonomous">Autonomous Actions</a>
        <a href="/pricing">Pricing</a>
      </div>

      <div class="footer-col">
        <div class="col-title">RESOURCES</div>
        <a href="/resources/blog">Blog</a>
        <a href="/resources/documentation">Documentation</a>
        <a href="/resources/case-studies">Case Studies</a>
        <a href="/resources/changelog">Changelog</a>
        <a href="/resources/glossary">Glossary</a>
      </div>

      <div class="footer-col">
        <div class="col-title">COMPANY</div>
        <a href="/company/about">About</a>
        <a href="/company/careers">Careers</a>
        <a href="/company/press">Press</a>
        <a href="/company/contact">Contact</a>
        <a href="/company/partners">Partners</a>
      </div>

      <div class="footer-newsletter">
        <div class="col-title">GROWTH INTELLIGENCE</div>
        <p class="newsletter-desc">Weekly insights for mobile app founders. Real data, real frameworks.</p>
        <form class="newsletter-form" id="footerNewsletter">
          <input type="email" placeholder="your@email.com" required class="newsletter-input"/>
          <button type="submit" class="newsletter-btn">
            <span>Subscribe</span>
            <span class="btn-arrow">→</span>
          </button>
        </form>
        <p class="newsletter-fine">No spam. Unsubscribe anytime.</p>
      </div>

    </div>

    <div class="footer-divider">
      <div class="divider-glow"></div>
    </div>

    <div class="footer-bottom">
      <div class="footer-copy">
        © 2026 <span class="copy-brand">Madar AI</span>
        <span class="copy-sep">·</span>
        A product of <a href="https://zyrix.com" class="zyrix-link">Zyrix Global Technologies</a>
      </div>
      <div class="footer-legal">
        <a href="/legal/privacy">Privacy Policy</a>
        <a href="/legal/terms">Terms of Service</a>
        <a href="/legal/cookies">Cookies</a>
      </div>
    </div>

    <div class="footer-watermark">
      <span>MADAR</span>
    </div>

  </div>
</footer>

<script>
  function initFooter() {
    const form = document.getElementById('footerNewsletter');
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input');
      const btn = form.querySelector('button span:first-child');
      if (!input || !btn) return;
      const email = input.value;
      btn.textContent = 'Subscribing...';
      try {
        const res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });
        if (res.ok) {
          btn.textContent = '✓ Subscribed';
          input.value = '';
          setTimeout(() => { btn.textContent = 'Subscribe'; }, 3000);
        } else {
          btn.textContent = 'Try again';
        }
      } catch {
        btn.textContent = 'Subscribe';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFooter);
  } else {
    initFooter();
  }
</script>

<style>
  .madar-footer {
    position: relative;
    background: linear-gradient(180deg, #050039 0%, #02001F 100%);
    color: white;
    padding: 80px 32px 32px;
    overflow: hidden;
  }

  .footer-glow-top {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 70%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(16, 240, 160, 0.5), transparent);
    pointer-events: none;
  }

  .footer-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  .footer-brand-col { display: flex; flex-direction: column; gap: 20px; }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .footer-logo {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    background: linear-gradient(135deg, #10F0A0 0%, #00D4A3 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 16px rgba(16, 240, 160, 0.4);
    color: #0A0070;
    font-weight: 700;
    font-size: 18px;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .footer-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .footer-brand-name {
    color: white;
    font-weight: 600;
    font-size: 16px;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .footer-brand-ai { color: #10F0A0; }

  .footer-brand-sub {
    color: rgba(255, 255, 255, 0.4);
    font-size: 9px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    letter-spacing: 0.15em;
    margin-top: 2px;
  }

  .footer-tagline {
    color: rgba(255, 255, 255, 0.6);
    font-size: 13px;
    line-height: 1.6;
    margin: 0;
    max-width: 320px;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: rgba(16, 240, 160, 0.08);
    border: 1px solid rgba(16, 240, 160, 0.2);
    border-radius: 100px;
    width: fit-content;
  }

  .status-dot {
    position: relative;
    width: 6px;
    height: 6px;
    background: #10F0A0;
    border-radius: 50%;
    box-shadow: 0 0 8px #10F0A0;
  }

  .status-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1px solid #10F0A0;
    animation: statusPulse 2s ease-out infinite;
  }

  @keyframes statusPulse {
    0% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(2); }
  }

  .status-text {
    color: #10F0A0;
    font-size: 11px;
    font-weight: 600;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .footer-socials {
    display: flex;
    gap: 8px;
  }

  .social-link {
    width: 32px;
    height: 32px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: all 0.25s;
  }

  .social-link:hover {
    background: rgba(16, 240, 160, 0.1);
    border-color: rgba(16, 240, 160, 0.3);
    color: #10F0A0;
    transform: translateY(-2px);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .col-title {
    color: #10F0A0;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    margin-bottom: 6px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .footer-col a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    text-decoration: none;
    transition: all 0.2s;
    font-family: 'Inter', system-ui, sans-serif;
    position: relative;
    padding-left: 0;
  }

  .footer-col a:hover {
    color: white;
    padding-left: 8px;
  }

  .footer-col a:hover::before {
    content: '→';
    position: absolute;
    left: -4px;
    color: #10F0A0;
  }

  .footer-newsletter { display: flex; flex-direction: column; gap: 12px; }

  .newsletter-desc {
    color: rgba(255, 255, 255, 0.65);
    font-size: 13px;
    line-height: 1.55;
    margin: 0;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .newsletter-form {
    display: flex;
    gap: 6px;
    margin-top: 4px;
  }

  .newsletter-input {
    flex: 1;
    min-width: 0;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 10px 12px;
    color: white;
    font-size: 12px;
    outline: none;
    transition: all 0.2s;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .newsletter-input::placeholder { color: rgba(255, 255, 255, 0.3); }

  .newsletter-input:focus {
    border-color: rgba(16, 240, 160, 0.5);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 0 3px rgba(16, 240, 160, 0.1);
  }

  .newsletter-btn {
    background: linear-gradient(135deg, #10F0A0, #5CFFC8);
    color: #0A0070;
    border: none;
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    box-shadow: 0 4px 12px rgba(16, 240, 160, 0.25);
    transition: all 0.2s;
    font-family: 'Inter', system-ui, sans-serif;
    white-space: nowrap;
  }

  .newsletter-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(16, 240, 160, 0.4);
  }

  .btn-arrow { transition: transform 0.2s; }
  .newsletter-btn:hover .btn-arrow { transform: translateX(2px); }

  .newsletter-fine {
    color: rgba(255, 255, 255, 0.35);
    font-size: 10px;
    margin: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .footer-divider {
    position: relative;
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin-bottom: 24px;
  }

  .divider-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(16, 240, 160, 0.4), transparent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    position: relative;
    z-index: 2;
  }

  .footer-copy {
    color: rgba(255, 255, 255, 0.5);
    font-size: 12px;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .copy-brand { color: white; font-weight: 600; }
  .copy-sep { margin: 0 6px; opacity: 0.5; }

  .zyrix-link {
    color: #10F0A0;
    text-decoration: none;
    transition: color 0.2s;
  }

  .zyrix-link:hover {
    color: #5CFFC8;
    text-shadow: 0 0 8px rgba(16, 240, 160, 0.4);
  }

  .footer-legal {
    display: flex;
    gap: 24px;
  }

  .footer-legal a {
    color: rgba(255, 255, 255, 0.5);
    font-size: 12px;
    text-decoration: none;
    transition: color 0.2s;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .footer-legal a:hover { color: white; }

  .footer-watermark {
    position: absolute;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 180px;
    font-weight: 900;
    letter-spacing: -0.05em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(16, 240, 160, 0.06);
    pointer-events: none;
    user-select: none;
    z-index: 0;
    font-family: 'Inter', system-ui, sans-serif;
    line-height: 0.9;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
      gap: 40px;
    }
    .footer-newsletter { grid-column: span 3; }
    .footer-watermark { font-size: 120px; }
  }

  @media (max-width: 640px) {
    .madar-footer { padding: 56px 20px 24px; }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .footer-brand-col, .footer-newsletter { grid-column: span 2; }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
    .footer-watermark { font-size: 80px; bottom: -20px; }
  }
</style>
