---
// Header.astro — Creative header with scroll-aware glass + mint progress bar + glow logo
---

<header class="madar-header" id="madarHeader">
  <div class="header-glow"></div>

  <div class="scroll-progress">
    <div class="scroll-progress-fill" id="scrollFill"></div>
  </div>

  <nav class="header-inner">
    <a href="/" class="header-brand">
      <div class="brand-logo">
        <div class="logo-glow"></div>
        <span class="logo-m">M</span>
      </div>
      <div class="brand-text">
        <span class="brand-name">Madar <span class="brand-ai">AI</span></span>
        <span class="brand-sub">GROWTH OS</span>
      </div>
    </a>

    <div class="header-nav-links">
      <a href="/product" class="nav-link">
        <span>Product</span>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.5 4 L5 6.5 L7.5 4"/></svg>
      </a>
      <a href="/pricing" class="nav-link"><span>Pricing</span></a>
      <a href="/resources" class="nav-link">
        <span>Resources</span>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.5 4 L5 6.5 L7.5 4"/></svg>
      </a>
      <a href="/company" class="nav-link">
        <span>Company</span>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.5 4 L5 6.5 L7.5 4"/></svg>
      </a>
      <a href="/community" class="nav-link"><span>Community</span></a>
    </div>

    <div class="header-right">
      <div class="lang-switch" id="langSwitch">
        <button class="lang-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12 h20 M12 2 a15 15 0 0 1 0 20 a15 15 0 0 1 0 -20"/>
          </svg>
          <span>EN</span>
        </button>
      </div>

      <a href="/login" class="header-login">Log in</a>

      <a href="/signup" class="header-cta">
        <span class="cta-text">Start free</span>
        <span class="cta-arrow">→</span>
        <span class="cta-glow"></span>
      </a>

      <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <div class="mobile-menu" id="mobileMenu">
    <a href="/product">Product</a>
    <a href="/pricing">Pricing</a>
    <a href="/resources">Resources</a>
    <a href="/company">Company</a>
    <a href="/community">Community</a>
    <div class="mobile-divider"></div>
    <a href="/login">Log in</a>
    <a href="/signup" class="mobile-cta">Start free →</a>
  </div>
</header>

<div class="header-spacer"></div>

<script>
  function initHeader() {
    const header = document.getElementById('madarHeader');
    const scrollFill = document.getElementById('scrollFill');
    const mobileToggle = document.getElementById('mobileToggle');
    const mobileMenu = document.getElementById('mobileMenu');

    if (!header) return;

    let lastScrollY = 0;
    let ticking = false;

    function updateHeader() {
      const scrollY = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollY / docHeight) * 100 : 0;

      if (scrollFill) {
        scrollFill.style.width = `${progress}%`;
      }

      if (scrollY > 24) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }

      lastScrollY = scrollY;
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(updateHeader);
        ticking = true;
      }
    }, { passive: true });

    if (mobileToggle && mobileMenu) {
      mobileToggle.addEventListener('click', () => {
        mobileToggle.classList.toggle('open');
        mobileMenu.classList.toggle('open');
      });
    }

    updateHeader();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeader);
  } else {
    initHeader();
  }
</script>

<style>
  .madar-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(8, 0, 70, 0.55);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .madar-header.scrolled {
    background: rgba(8, 0, 70, 0.85);
    border-bottom-color: rgba(16, 240, 160, 0.15);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
  }

  .header-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(16, 240, 160, 0.6), transparent);
    pointer-events: none;
  }

  .scroll-progress {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: rgba(255, 255, 255, 0.03);
  }

  .scroll-progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #10F0A0, #5CFFC8, #10F0A0);
    background-size: 200% 100%;
    animation: shimmer 3s linear infinite;
    box-shadow: 0 0 12px rgba(16, 240, 160, 0.8);
    transition: width 0.1s linear;
  }

  @keyframes shimmer {
    0% { background-position: 0% 0%; }
    100% { background-position: 200% 0%; }
  }

  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .madar-header.scrolled .header-inner {
    padding: 10px 32px;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
    position: relative;
  }

  .brand-logo {
    position: relative;
    width: 36px;
    height: 36px;
    border-radius: 9px;
    background: linear-gradient(135deg, #10F0A0 0%, #00D4A3 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 24px rgba(16, 240, 160, 0.55), 0 2px 8px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    transition: transform 0.3s;
  }

  .header-brand:hover .brand-logo {
    transform: rotate(-8deg) scale(1.08);
  }

  .logo-glow {
    position: absolute;
    inset: -4px;
    background: radial-gradient(circle, rgba(16, 240, 160, 0.7), transparent);
    filter: blur(8px);
    opacity: 0.6;
    z-index: -1;
    animation: pulseGlow 3s ease-in-out infinite;
  }

  @keyframes pulseGlow {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.15); }
  }

  .logo-m {
    font-weight: 700;
    color: #0A0070;
    font-size: 18px;
    font-family: 'Inter', system-ui, sans-serif;
    position: relative;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .brand-name {
    color: white;
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.01em;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .brand-ai { color: #10F0A0; }

  .brand-sub {
    color: rgba(255, 255, 255, 0.45);
    font-size: 9px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    letter-spacing: 0.15em;
    margin-top: 2px;
  }

  .header-nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 8px;
    transition: all 0.2s;
    font-family: 'Inter', system-ui, sans-serif;
    position: relative;
  }

  .nav-link::before {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background: #10F0A0;
    box-shadow: 0 0 8px #10F0A0;
    transition: width 0.25s ease;
    border-radius: 2px;
  }

  .nav-link:hover {
    color: white;
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-link:hover::before {
    width: 18px;
  }

  .nav-link svg {
    opacity: 0.5;
    transition: transform 0.2s;
  }

  .nav-link:hover svg {
    opacity: 1;
    transform: translateY(1px);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .lang-switch { position: relative; }

  .lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: rgba(255, 255, 255, 0.85);
    padding: 7px 12px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    cursor: pointer;
    transition: all 0.2s;
  }

  .lang-btn:hover {
    background: rgba(255, 255, 255, 0.10);
    border-color: rgba(16, 240, 160, 0.3);
  }

  .header-login {
    color: rgba(255, 255, 255, 0.85);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 8px;
    transition: all 0.2s;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .header-login:hover {
    color: white;
    background: rgba(255, 255, 255, 0.05);
  }

  .header-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(135deg, #10F0A0 0%, #5CFFC8 100%);
    color: #0A0070;
    font-size: 14px;
    font-weight: 700;
    padding: 9px 18px;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(16, 240, 160, 0.35);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .header-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(16, 240, 160, 0.55);
  }

  .cta-text { position: relative; z-index: 2; }

  .cta-arrow {
    position: relative;
    z-index: 2;
    transition: transform 0.25s;
    font-size: 16px;
  }

  .header-cta:hover .cta-arrow {
    transform: translateX(4px);
  }

  .cta-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s;
  }

  .header-cta:hover .cta-glow {
    transform: translateX(100%);
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: white;
    border-radius: 2px;
    transition: all 0.3s;
  }

  .mobile-toggle.open span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .mobile-toggle.open span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 16px 32px 24px;
    background: rgba(8, 0, 70, 0.95);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s;
  }

  .mobile-menu.open {
    max-height: 500px;
    padding-top: 16px;
    padding-bottom: 24px;
  }

  .mobile-menu a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 500;
  }

  .mobile-menu a:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .mobile-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 8px 0;
  }

  .mobile-cta {
    background: linear-gradient(135deg, #10F0A0, #5CFFC8);
    color: #0A0070 !important;
    font-weight: 700 !important;
    text-align: center;
    box-shadow: 0 4px 16px rgba(16, 240, 160, 0.3);
  }

  .header-spacer { height: 64px; }

  @media (max-width: 1024px) {
    .header-nav-links { display: none; }
  }

  @media (max-width: 768px) {
    .header-inner { padding: 12px 20px; gap: 12px; }
    .madar-header.scrolled .header-inner { padding: 8px 20px; }
    .lang-switch, .header-login { display: none; }
    .mobile-toggle { display: flex; }
    .mobile-menu { display: flex; }
    .brand-sub { display: none; }
    .header-cta { padding: 8px 14px; font-size: 13px; }
  }

  @media (max-width: 480px) {
    .header-cta .cta-text { display: none; }
  }
</style>
