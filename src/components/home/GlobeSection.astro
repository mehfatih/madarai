---
// GlobeSection.astro — Three.js 3D globe with country pins
---

<section class="globe-wrap">
  <div class="globe-bg-fx"></div>

  <div class="globe-head">
    <div class="globe-badge">
      <span class="mint-dot"></span>
      <span>GLOBAL REACH</span>
    </div>
    <h2 class="globe-title">
      Built for founders<br/>
      <span class="grad-mint">everywhere they ship.</span>
    </h2>
    <p class="globe-sub">
      70+ countries across MENA, Türkiye, Europe, and global markets. Native support for Arabic, Turkish, and English.
    </p>
  </div>

  <div class="globe-canvas-container">
    <div id="madar-globe" class="globe-canvas">
      <div class="globe-loading">Initializing 3D globe...</div>
    </div>

    <div class="globe-badge-tracking">
      <div class="tracking-line">
        <span class="mint-pulse"><span class="ping"></span><span class="core"></span></span>
        <span class="tracking-label">LIVE TRACKING</span>
      </div>
      <div class="tracking-value">2,847 events/sec</div>
    </div>

    <div class="globe-badge-drag">
      <div class="drag-label">DRAG TO ROTATE</div>
      <div class="drag-icon">
        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="#10F0A0" stroke-width="2.5" stroke-linecap="round">
          <path d="M9 11 l3 -3 l3 3"/>
          <path d="M9 13 l3 3 l3 -3"/>
        </svg>
        <span>interactive</span>
      </div>
    </div>
  </div>

  <div class="network-panel">
    <div class="network-head">
      <div class="network-live">
        <span class="mint-pulse big"><span class="ping"></span><span class="core"></span></span>
        <span>LIVE NETWORK ACTIVITY</span>
      </div>
      <span class="network-timeframe">Last 24 hours</span>
    </div>

    <div class="network-grid">
      <div class="chart-cell">
        <div class="chart-label">EVENTS PROCESSED / HOUR</div>
        <svg viewBox="0 0 400 90" preserveAspectRatio="none" class="chart-svg">
          <defs>
            <linearGradient id="chart-fill-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#10F0A0" stop-opacity="0.5"/>
              <stop offset="100%" stop-color="#10F0A0" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <g stroke="rgba(255,255,255,0.06)" stroke-width="0.5">
            <line x1="0" y1="22" x2="400" y2="22"/>
            <line x1="0" y1="45" x2="400" y2="45"/>
            <line x1="0" y1="68" x2="400" y2="68"/>
          </g>
          <path d="M 0,72 L 25,68 L 50,62 L 75,65 L 100,55 L 125,48 L 150,52 L 175,40 L 200,42 L 225,30 L 250,35 L 275,22 L 300,28 L 325,18 L 350,22 L 375,12 L 400,8 L 400,90 L 0,90 Z" fill="url(#chart-fill-grad)"/>
          <path d="M 0,72 L 25,68 L 50,62 L 75,65 L 100,55 L 125,48 L 150,52 L 175,40 L 200,42 L 225,30 L 250,35 L 275,22 L 300,28 L 325,18 L 350,22 L 375,12 L 400,8" fill="none" stroke="#10F0A0" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="400" cy="8" r="3" fill="#10F0A0" stroke="white" stroke-width="1"/>
        </svg>
      </div>

      <div class="stat-cell">
        <div class="stat-mini-lbl">CONTINENTS</div>
        <div class="stat-mini-val">5</div>
        <div class="stat-mini-sub mint">↑ active</div>
      </div>

      <div class="stat-cell">
        <div class="stat-mini-lbl">COUNTRIES</div>
        <div class="stat-mini-val">70<span class="accent">+</span></div>
        <div class="stat-mini-sub mint">↑ +12 this Q</div>
      </div>

      <div class="stat-cell">
        <div class="stat-mini-lbl">LANGUAGES</div>
        <div class="stat-mini-val">3</div>
        <div class="stat-mini-sub">EN · AR · TR</div>
      </div>
    </div>
  </div>
</section>

<script>
  import * as THREE from 'three';

  function initGlobe() {
    const container = document.getElementById('madar-globe');
    if (!container) return;

    container.innerHTML = '';

    const parent = container.parentElement;
    const width = parent.clientWidth;
    const height = parent.clientHeight;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
    camera.position.z = 320;

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(width, height);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    const RADIUS = 100;
    const earthTextureUrl = 'https://unpkg.com/three-globe@2.31.1/example/img/earth-blue-marble.jpg';
    const textureLoader = new THREE.TextureLoader();
    textureLoader.crossOrigin = 'anonymous';

    const sphereGeo = new THREE.SphereGeometry(RADIUS, 64, 64);
    const sphereMat = new THREE.MeshPhongMaterial({
      color: 0x2A5A9F,
      emissive: 0x0A1F3D,
      emissiveIntensity: 0.15,
      shininess: 10
    });
    const earthMesh = new THREE.Mesh(sphereGeo, sphereMat);
    scene.add(earthMesh);

    textureLoader.load(earthTextureUrl, (texture) => {
      sphereMat.map = texture;
      sphereMat.color.setHex(0xFFFFFF);
      sphereMat.emissive.setHex(0x112244);
      sphereMat.emissiveIntensity = 0.3;
      sphereMat.needsUpdate = true;
    });

    const atmGeo = new THREE.SphereGeometry(RADIUS * 1.08, 64, 64);
    const atmMat = new THREE.ShaderMaterial({
      uniforms: {},
      vertexShader: 'varying vec3 vNormal; void main(){ vNormal = normalize(normalMatrix * normal); gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0); }',
      fragmentShader: 'varying vec3 vNormal; void main(){ float intensity = pow(0.6 - dot(vNormal, vec3(0,0,1.0)), 2.5); gl_FragColor = vec4(0.063, 0.941, 0.627, 1.0) * intensity; }',
      blending: THREE.AdditiveBlending,
      side: THREE.BackSide,
      transparent: true
    });
    scene.add(new THREE.Mesh(atmGeo, atmMat));

    scene.add(new THREE.AmbientLight(0xFFFFFF, 0.7));
    const directional = new THREE.DirectionalLight(0xFFFFFF, 0.8);
    directional.position.set(5, 3, 5);
    scene.add(directional);
    const rim = new THREE.DirectionalLight(0x10F0A0, 0.4);
    rim.position.set(-5, 0, -3);
    scene.add(rim);

    const COUNTRIES = [
      { name: 'Türkiye', lat: 39, lng: 35, size: 1.4 },
      { name: 'Saudi Arabia', lat: 24, lng: 45, size: 1.4 },
      { name: 'UAE', lat: 24, lng: 54, size: 1.1 },
      { name: 'Egypt', lat: 27, lng: 30, size: 1.2 },
      { name: 'Kuwait', lat: 29, lng: 47, size: 0.9 },
      { name: 'Qatar', lat: 25, lng: 51, size: 0.9 },
      { name: 'Oman', lat: 21, lng: 56, size: 1 },
      { name: 'Jordan', lat: 31, lng: 36, size: 0.9 },
      { name: 'Lebanon', lat: 34, lng: 36, size: 0.9 },
      { name: 'Tunisia', lat: 34, lng: 9, size: 0.9 },
      { name: 'Algeria', lat: 28, lng: 3, size: 1 },
      { name: 'Morocco', lat: 32, lng: -6, size: 1 },
      { name: 'Libya', lat: 27, lng: 17, size: 0.9 },
      { name: 'Iraq', lat: 33, lng: 44, size: 1 },
      { name: 'UK', lat: 54, lng: -2, size: 1 },
      { name: 'Germany', lat: 51, lng: 10, size: 1 },
      { name: 'France', lat: 47, lng: 2, size: 1 },
      { name: 'Italy', lat: 43, lng: 12, size: 1 },
      { name: 'Spain', lat: 40, lng: -4, size: 1 },
      { name: 'Netherlands', lat: 52, lng: 5, size: 0.8 },
      { name: 'Sweden', lat: 62, lng: 16, size: 0.8 },
      { name: 'Poland', lat: 52, lng: 19, size: 0.9 },
      { name: 'Greece', lat: 39, lng: 22, size: 0.9 },
      { name: 'USA NY', lat: 40, lng: -74, size: 1.3 },
      { name: 'USA LA', lat: 34, lng: -118, size: 1.2 },
      { name: 'Mexico', lat: 23, lng: -102, size: 1 },
      { name: 'Brazil', lat: -14, lng: -52, size: 1.1 },
      { name: 'India', lat: 21, lng: 78, size: 1.2 },
      { name: 'Japan', lat: 36, lng: 138, size: 1.4 },
      { name: 'South Korea', lat: 36, lng: 128, size: 1 },
      { name: 'Indonesia', lat: -2, lng: 118, size: 1 },
      { name: 'Pakistan', lat: 30, lng: 70, size: 0.9 },
      { name: 'Nigeria', lat: 9, lng: 8, size: 0.9 },
      { name: 'South Africa', lat: -30, lng: 25, size: 0.9 },
      { name: 'Australia', lat: -25, lng: 134, size: 1 }
    ];

    const HIGHLIGHTED = ['Türkiye', 'Saudi Arabia', 'Japan', 'USA NY'];

    function latLngToXYZ(lat, lng, r) {
      const phi = (90 - lat) * (Math.PI / 180);
      const theta = (lng + 180) * (Math.PI / 180);
      return {
        x: -(r * Math.sin(phi) * Math.cos(theta)),
        y: r * Math.cos(phi),
        z: r * Math.sin(phi) * Math.sin(theta)
      };
    }

    const pinsGroup = new THREE.Group();
    const ringsGroup = new THREE.Group();
    earthMesh.add(pinsGroup);
    earthMesh.add(ringsGroup);

    COUNTRIES.forEach((country) => {
      const pos = latLngToXYZ(country.lat, country.lng, RADIUS * 1.005);

      const dot = new THREE.Mesh(
        new THREE.SphereGeometry(country.size, 12, 12),
        new THREE.MeshBasicMaterial({ color: 0x10F0A0 })
      );
      dot.position.set(pos.x, pos.y, pos.z);
      pinsGroup.add(dot);

      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(country.size * 1.8, 12, 12),
        new THREE.MeshBasicMaterial({ color: 0x10F0A0, transparent: true, opacity: 0.3 })
      );
      glow.position.set(pos.x, pos.y, pos.z);
      pinsGroup.add(glow);

      if (HIGHLIGHTED.indexOf(country.name) > -1) {
        const ring = new THREE.Mesh(
          new THREE.RingGeometry(country.size * 1.5, country.size * 1.8, 32),
          new THREE.MeshBasicMaterial({
            color: 0x10F0A0,
            side: THREE.DoubleSide,
            transparent: true,
            opacity: 0.8
          })
        );
        ring.position.set(pos.x, pos.y, pos.z);
        ring.lookAt(0, 0, 0);
        ring.userData = { baseSize: country.size, phase: Math.random() * Math.PI * 2 };
        ringsGroup.add(ring);
      }
    });

    function makeArc(startLatLng, endLatLng) {
      const start = latLngToXYZ(startLatLng[0], startLatLng[1], RADIUS * 1.005);
      const end = latLngToXYZ(endLatLng[0], endLatLng[1], RADIUS * 1.005);
      const startV = new THREE.Vector3(start.x, start.y, start.z);
      const endV = new THREE.Vector3(end.x, end.y, end.z);
      const midV = startV.clone().add(endV).multiplyScalar(0.5);
      const distance = startV.distanceTo(endV);
      midV.normalize().multiplyScalar(RADIUS + distance * 0.35);
      const curve = new THREE.QuadraticBezierCurve3(startV, midV, endV);
      const points = curve.getPoints(60);
      return new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(points),
        new THREE.LineBasicMaterial({ color: 0x10F0A0, transparent: true, opacity: 0.5 })
      );
    }

    [
      makeArc([39, 35], [40, -74]),
      makeArc([24, 45], [36, 138]),
      makeArc([39, 35], [51, 10]),
      makeArc([24, 54], [21, 78]),
      makeArc([40, -74], [-14, -52])
    ].forEach((arc) => earthMesh.add(arc));

    let isDragging = false;
    let prevMouse = { x: 0, y: 0 };
    let rotationVelocity = { x: 0, y: 0.0015 };

    renderer.domElement.style.cursor = 'grab';
    renderer.domElement.addEventListener('mousedown', (e) => {
      isDragging = true;
      prevMouse.x = e.clientX;
      prevMouse.y = e.clientY;
      renderer.domElement.style.cursor = 'grabbing';
    });
    window.addEventListener('mouseup', () => {
      isDragging = false;
      renderer.domElement.style.cursor = 'grab';
    });
    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      rotationVelocity.y = (e.clientX - prevMouse.x) * 0.005;
      rotationVelocity.x = (e.clientY - prevMouse.y) * 0.005;
      prevMouse.x = e.clientX;
      prevMouse.y = e.clientY;
    });

    renderer.domElement.addEventListener('touchstart', (e) => {
      if (e.touches.length === 1) {
        isDragging = true;
        prevMouse.x = e.touches[0].clientX;
        prevMouse.y = e.touches[0].clientY;
      }
    });
    renderer.domElement.addEventListener('touchend', () => { isDragging = false; });
    renderer.domElement.addEventListener('touchmove', (e) => {
      if (!isDragging || e.touches.length !== 1) return;
      rotationVelocity.y = (e.touches[0].clientX - prevMouse.x) * 0.005;
      rotationVelocity.x = (e.touches[0].clientY - prevMouse.y) * 0.005;
      prevMouse.x = e.touches[0].clientX;
      prevMouse.y = e.touches[0].clientY;
      e.preventDefault();
    });

    let time = 0;
    function animate() {
      requestAnimationFrame(animate);
      time += 0.015;

      if (!isDragging) {
        rotationVelocity.y = rotationVelocity.y * 0.95 + 0.0015 * 0.05;
        rotationVelocity.x = rotationVelocity.x * 0.92;
      }

      earthMesh.rotation.y += rotationVelocity.y;
      earthMesh.rotation.x += rotationVelocity.x;
      earthMesh.rotation.x = Math.max(-0.8, Math.min(0.8, earthMesh.rotation.x));

      ringsGroup.children.forEach((ring) => {
        const pulse = (Math.sin(time + ring.userData.phase) + 1) / 2;
        const scale = 1 + pulse * 1.5;
        ring.scale.set(scale, scale, scale);
        ring.material.opacity = 0.8 - pulse * 0.7;
      });

      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
      const w = parent.clientWidth;
      const h = parent.clientHeight;
      renderer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGlobe);
  } else {
    initGlobe();
  }
</script>

<style>
  .globe-wrap {
    background: linear-gradient(180deg, #0A0070 0%, #11008F 100%);
    padding: 80px 24px 100px;
    position: relative;
    overflow: hidden;
  }

  .globe-bg-fx {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 50% 50%, rgba(16, 240, 160, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .globe-head {
    position: relative;
    text-align: center;
    margin-bottom: 48px;
  }

  .globe-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(16, 240, 160, 0.12);
    border: 1px solid rgba(16, 240, 160, 0.3);
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
    color: #10F0A0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .mint-dot {
    width: 6px;
    height: 6px;
    background: #10F0A0;
    border-radius: 50%;
    box-shadow: 0 0 8px #10F0A0;
  }

  .globe-title {
    color: white;
    font-size: clamp(28px, 4.5vw, 40px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 16px;
  }

  .grad-mint {
    background: linear-gradient(135deg, #10F0A0, #5CFFC8);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .globe-sub {
    color: rgba(255, 255, 255, 0.7);
    font-size: 16px;
    line-height: 1.6;
    max-width: 580px;
    margin: 0 auto;
  }

  .globe-canvas-container {
    position: relative;
    max-width: 560px;
    height: 560px;
    margin: 0 auto;
  }

  .globe-canvas {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .globe-loading {
    color: rgba(255, 255, 255, 0.5);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
  }

  .globe-badge-tracking {
    position: absolute;
    top: 16px;
    right: 16px;
    background: rgba(8, 0, 70, 0.7);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(16, 240, 160, 0.25);
    border-radius: 10px;
    padding: 10px 14px;
    z-index: 10;
  }

  .tracking-line {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .mint-pulse {
    position: relative;
    display: inline-flex;
    width: 7px;
    height: 7px;
  }

  .mint-pulse.big { width: 8px; height: 8px; }

  .mint-pulse .ping {
    position: absolute;
    inset: 0;
    background: #10F0A0;
    border-radius: 50%;
    animation: pingPulse 2s infinite;
  }

  .mint-pulse .core {
    position: relative;
    background: #10F0A0;
    border-radius: 50%;
    width: 100%;
    height: 100%;
    box-shadow: 0 0 8px #10F0A0;
  }

  @keyframes pingPulse {
    0% { transform: scale(1); opacity: 1; }
    75%, 100% { transform: scale(2.5); opacity: 0; }
  }

  .tracking-label {
    color: #10F0A0;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .tracking-value {
    color: white;
    font-size: 11px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .globe-badge-drag {
    position: absolute;
    bottom: 16px;
    left: 16px;
    background: rgba(8, 0, 70, 0.7);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    padding: 10px 14px;
    z-index: 10;
  }

  .drag-label {
    color: rgba(255, 255, 255, 0.55);
    font-size: 9px;
    letter-spacing: 0.15em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    margin-bottom: 4px;
  }

  .drag-icon {
    display: flex;
    align-items: center;
    gap: 6px;
    color: white;
    font-size: 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .network-panel {
    position: relative;
    max-width: 900px;
    margin: 56px auto 0;
    background: rgba(8, 0, 70, 0.55);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(16, 240, 160, 0.18);
    border-radius: 16px;
    padding: 22px;
    overflow: hidden;
  }

  .network-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, #10F0A0, transparent);
  }

  .network-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .network-live {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #10F0A0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .network-timeframe {
    color: rgba(255, 255, 255, 0.5);
    font-size: 11px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .network-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 20px;
    align-items: center;
  }

  .chart-cell {
    position: relative;
    height: 90px;
  }

  .chart-label {
    color: rgba(255, 255, 255, 0.5);
    font-size: 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    letter-spacing: 0.15em;
    position: absolute;
    top: 0; left: 0;
  }

  .chart-svg {
    width: 100%;
    height: 100%;
  }

  .stat-mini-lbl {
    color: rgba(255, 255, 255, 0.5);
    font-size: 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    letter-spacing: 0.15em;
    margin-bottom: 4px;
  }

  .stat-mini-val {
    color: white;
    font-size: 28px;
    font-weight: 700;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat-mini-val .accent { color: #10F0A0; }

  .stat-mini-sub {
    color: rgba(255, 255, 255, 0.55);
    font-size: 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    margin-top: 4px;
  }

  .stat-mini-sub.mint { color: #10F0A0; }

  @media (max-width: 768px) {
    .globe-canvas-container { max-width: 100%; height: 400px; }
    .network-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
    .chart-cell { grid-column: 1 / -1; }
  }
</style>
